# Data middleware API URL
VITE_API=http://localhost:4200

# Strapi CMS
VITE_CMS_API=https://your-cms.example.com/api
VITE_CMS_TOKEN=your_strapi_token_here

# App base URL (used by Cypress)
VITE_BASE_URL=http://localhost:3000

# Mapbox
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Auth0
VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
VITE_AUTH0_CLIENT=your_auth0_client_id
VITE_AUTH0_AUDIENCE=https://your-tenant.eu.auth0.com/api/v2/

# -------------------------------------------------------------------------
# AI Explorer
# Set VITE_APP_ENV=staging to activate the basic-auth gate on /ai-explorer.
# (soft gate: frontend obfuscation only, not real security,
# this needs to be set in staging to avoid exposing the page in production
# without basicauth authentication)
# On any other value (or if unset) the page is accessible without a prompt.
# Leave VITE_AI_EXPLORER_BASIC_AUTH_USER / _PASS unset to skip the gate even
# on staging (useful for automated E2E runs).
# -------------------------------------------------------------------------
VITE_APP_ENV=staging
VITE_AI_EXPLORER_BASIC_AUTH_USER=your_username
VITE_AI_EXPLORER_BASIC_AUTH_PASS=your_password
